{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Wiki Domain Map",
  "version": "1.0.0",
  "wiki_root": ".wiki",
  "domains": [
    {
      "id": "документация",
      "name": "Документация obsidian-llm-wiki",
      "source_paths": ["docs"],
      "wiki_subfolder": "документация",
      "tags": ["obsidian", "plugin", "typescript"],
      "language_notes": "ru/en смешанный — термины TypeScript/Obsidian оставлять на английском",
      "entity_types": [
        {
          "type": "компонент",
          "description": "TypeScript-модуль или класс плагина (WikiController, AgentRunner, LlmWikiView и т.д.)",
          "extraction_cues": ["controller", "runner", "view", "client", "phase", "модуль", "класс", "src/", ".ts", "export class", "export function"],
          "min_mentions_for_page": 2,
          "wiki_subfolder": "документация/компоненты"
        },
        {
          "type": "операция",
          "description": "Wiki-операция плагина (ingest, query, lint, fix, init, chat, format)",
          "extraction_cues": ["ingest", "query", "query-save", "lint", "fix", "init", "chat", "format", "operation", "операция", "dispatch"],
          "min_mentions_for_page": 1,
          "wiki_subfolder": "документация/операции"
        },
        {
          "type": "паттерн",
          "description": "Архитектурный паттерн или техническое решение (Single-Flight, AsyncGenerator, Backend Strategy, Per-Device Settings и т.д.)",
          "extraction_cues": ["pattern", "паттерн", "single-flight", "async generator", "strategy", "guard", "overlay", "migration", "решение"],
          "min_mentions_for_page": 2,
          "wiki_subfolder": "документация/паттерны"
        },
        {
          "type": "спецификация",
          "description": "Дизайн-документ или спецификация функциональности (specs/)",
          "extraction_cues": ["design", "spec", "спецификация", "дизайн", "цель", "архитектура", "ux-поток", "контракт", "§"],
          "min_mentions_for_page": 1,
          "wiki_subfolder": "документация/спецификации"
        },
        {
          "type": "план",
          "description": "Реализационный план задачи (plans/)",
          "extraction_cues": ["plan", "план", "task", "step", "- [ ]", "реализация", "implementation", "goal"],
          "min_mentions_for_page": 1,
          "wiki_subfolder": "документация/планы"
        }
      ],
      "cross_domain_refs": []
    }
  ],
  "cross_domain_rules": {
    "description": "Правила для сущностей, встречающихся в нескольких доменах",
    "rules": []
  },
  "special_source_types": {},
  "source_types": {
    ".md": {
      "reader": "markdown",
      "extract": ["narrative", "frontmatter", "code_blocks", "headings"],
      "rules_file": "rules/readers/markdown.md"
    },
    ".py": {
      "reader": "python",
      "extract": ["public_api", "docstrings", "types", "imports"],
      "rules_file": "rules/readers/python.md"
    },
    ".ts": {
      "reader": "typescript",
      "extract": ["public_api", "docstrings", "types", "imports"],
      "rules_file": "rules/readers/typescript.md"
    },
    ".tsx": {
      "reader": "typescript",
      "extract": ["public_api", "docstrings", "types", "imports"],
      "rules_file": "rules/readers/typescript.md"
    },
    ".js": {
      "reader": "javascript",
      "extract": ["public_api", "docstrings", "imports"],
      "rules_file": "rules/readers/javascript.md"
    },
    ".mjs": {
      "reader": "javascript",
      "extract": ["public_api", "docstrings", "imports"],
      "rules_file": "rules/readers/javascript.md"
    },
    ".sh": {
      "reader": "bash",
      "extract": ["functions", "flags", "exports", "comments"],
      "rules_file": "rules/readers/bash.md"
    },
    ".yaml": {
      "reader": "markdown",
      "extract": ["narrative", "headings"],
      "rules_file": "rules/readers/markdown.md"
    }
  }
}
