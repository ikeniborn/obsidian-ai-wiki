# --- сеть ---
HTTPS_PROXY=http://user:password@ft.ikeniborn.ru:8118
HTTP_PROXY=http://user:password@ft.ikeniborn.ru:8118
NO_PROXY=localhost,127.0.0.1

# --- бэкенд ---
DSPY_BACKEND=ollama          # ollama | ollama-openai | claude-code

# ollama — нативный API (/api/generate), локальные модели
# ollama-openai — OpenAI-compat API (/v1/chat/completions), нужен для облачных моделей Ollama (:cloud)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2        # или deepseek-v4-pro:cloud для облачного доступа
OLLAMA_API_KEY=ollama

# claude-code (использует существующую сессию Claude Code, API-ключ не нужен)
CLAUDE_PATH=/usr/local/bin/claude
CLAUDE_MODEL=claude-sonnet-4-6  # или алиас: sonnet | haiku | opus

# --- данные ---
# Input: human 👍/👎 ratings from the plugin's eval.jsonl (no LLM judge)
DEV_LOG_PATH=/path/to/vault/.obsidian/plugins/ai-wiki/eval.jsonl

# --- параметры оптимизации ---
OPERATIONS=query,chat,format  # если пусто — все операции из лога; format разбивается на format:vision-on / format:vision-off
MIN_EXAMPLES=5
PROMPTS_DIR=/absolute/path/to/prompts
OUTPUT_DIR=/absolute/path/to/prompts/optimized
