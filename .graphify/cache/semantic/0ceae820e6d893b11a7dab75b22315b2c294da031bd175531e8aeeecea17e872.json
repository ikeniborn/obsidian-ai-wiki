architecture/overview.yaml", "source_location": "key_constraints Format stripCodeFence anchored (v0.1.68)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Previous greedy regex caught FIRST internal markdown fence (```sql, ```bash) from formatted field, returning block without {, causing false JSON-invalid \u2192 retry \u2192 final error. Haiku masked bug with its own outer fence. Anchored regex fixes this."}, {"id": "overview_format_json_robustness", "label": "Format JSON Robustness (response_format json_object, extractJsonObject, repairJson, auto-retry)", "file_type": "rationale", "source_file": "docs/architecture/overview.yaml", "source_location": "key_constraints Format JSON-\u0443\u0441\u0442\u043e\u0439\u0447\u0438\u0432\u043e\u0441\u0442\u044c (v0.1.63+)", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "overview_large_payload_handling", "label": "ClaudeCliClient Large-Payload Handling (LARGE_THRESHOLD 256KB, tmp file via --append-system-prompt-file)", "file_type": "rationale", "source_file": "docs/architecture/overview.yaml", "source_location": "key_constraints ClaudeCliClient large-payload (v0.1.63+)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Old '-p .' workaround caused haiku to respond 'Dot received. What's next?' losing all content. Threshold 256KB is safe below Linux ARG_MAX ~2MB."}, {"id": "overview_per_device_settings_overlay", "label": "Per-Device Settings Overlay (data.json synced + local.json per-device)", "file_type": "rationale", "source_file": "docs/architecture/overview.yaml", "source_location": "key_constraints Per-device overlay", "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "overview_llm_wiki_plugin", "target": "overview_layered_architecture", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/architecture/o