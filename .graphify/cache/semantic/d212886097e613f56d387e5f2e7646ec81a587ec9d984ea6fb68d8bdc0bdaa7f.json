{"nodes": [{"id": "claude_plugin_overview", "label": "obsidian-llm-wiki Plugin", "file_type": "document", "source_file": "CLAUDE.md", "source_location": "Overview", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Obsidian plugin that performs wiki operations (ingest/query/lint/fix/init/chat) via TypeScript phases with LLM backend, displaying progress in a sidebar in real time."}, {"id": "claude_wikicontroller", "label": "WikiController", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "src/controller.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Implements single-flight guard and path validation (cwd/iclaudePath). Rejects parallel runs via this._running to prevent stdout stream corruption."}, {"id": "claude_agentrunner", "label": "AgentRunner", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "src/agent-runner.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Routes operations to the appropriate TypeScript phase, handles dev logging and evaluation."}, {"id": "claude_claudecliclient", "label": "ClaudeCliClient", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "src/claude-cli-client.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Spawns iclaude.sh process, provides OpenAI-compatible LlmClient interface. Manages stdio with stdin closed, stdout/stderr captured. Handles SIGTERM -> 3000ms grace -> SIGKILL abort sequence."}, {"id": "claude_parsestreamline", "label": "parseStreamLine", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "src/stream.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Parses a single JSON line from iclaude stdout into a RunEvent. Non-JSON lines (iclaude banners) are ignored."}, {"id": "claude_llmwikiview", "label": "LlmWikiView", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "src/view.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Obsidian ItemView subclass that renders steps, metrics, and history live in the sidebar panel."}, {"id": "claude_main_ts", "label": "main.ts", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "src/main.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Plugin entry point; registers commands, view, and settings. Also the esbuild entrypoint producing main.js (CJS, ES2022)."}, {"id": "claude_settings_ts", "label": "settings.ts", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "src/settings.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Plugin settings and autodetectCwd() which walks up the directory tree up to 6 levels."}, {"id": "claude_types_ts", "label": "types.ts", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "src/types.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single source of truth for all TypeScript types: WikiOperation, RunEvent, LlmWikiPluginSettings, WikiDomain. WikiDomain union type on line 8 is the canonical domain registry."}, {"id": "claude_wikioperation", "label": "WikiOperation", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "src/types.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Enum/union type representing the supported wiki operations: ingest, query, lint, fix, init, chat. Each has its own timeout setting."}, {"id": "claude_runevent", "label": "RunEvent", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "src/types.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Typed representation of a parsed stream-json line from iclaude stdout. Variants: system/init, system/error, assistant, user/tool_result, result."}, {"id": "claude_wikidomain", "label": "WikiDomain", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "src/types.ts line 8", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Union type '\u0438\u0438' | '\u0440\u043e\u0441\u0442\u0435\u043b\u0435\u043a\u043e\u043c' | '\u0431\u0430\u0437\u044b-\u0434\u0430\u043d\u043d\u044b\u0445'. Single source of truth for all domain values \u2014 only this type should be modified when adding a domain."}, {"id": "claude_streamjson_protocol", "label": "stream-json protocol", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "\u041f\u0440\u043e\u0442\u043e\u043a\u043e\u043b stream-json", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each stdout line from iclaude is one JSON object. Types: system (init|error), assistant (tool_use|text), user (tool_result), result (duration_ms, total_cost_usd, is_error). Non-JSON lines are ignored."}, {"id": "claude_singleflight", "label": "single-flight guard", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Rules", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Only one operation runs at a time. controller.ts rejects parallel launches via this._running. Parallel spawning would corrupt the stdout stream. Other callers receive an Obsidian Notice."}, {"id": "claude_iclaude_sh", "label": "iclaude.sh", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "Rules", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Shell wrapper spawned by ClaudeCliClient. Reserves -p/--proxy for proxy URL. Flags must be passed as: iclaude.sh flags (--no-proxy, --model) then -- then claude flags (-p <prompt>, --output-format). Violating this causes exit 1 with no stderr."}, {"id": "claude_history_limit", "label": "historyLimit", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Rules", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Default 20. History stored in Obsidian settings. Exceeding the limit slows Obsidian's settings.json save. The value is a UX vs. settings.json size tradeoff."}, {"id": "claude_versioning", "label": "versioning workflow", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Build & Versioning", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Before every build: auto-increment patch version in package.json and src/manifest.json, then run npm run build. Minor and major bumps are manual only."}, {"id": "claude_esbuild_config", "label": "esbuild.config.mjs", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "Build & Versioning", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Build config: entrypoint src/main.ts -> main.js (CJS, ES2022). Externals: obsidian, electron, node:child_process, node:readline. path-browserify is bundled; node:path and node:fs are removed from externals."}, {"id": "claude_test_stream", "label": "tests/stream.test.ts", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "Testing", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tests parseStreamLine() with fixture JSONL."}, {"id": "claude_test_settings", "label": "tests/settings.test.ts", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "Testing", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tests autodetectCwd() directory walk-up behavior."}, {"id": "claude_test_claudecliclient", "label": "tests/claude-cli-client.test.ts", "file_type": "code", "source_file": "CLAUDE.md", "source_location": "Testing", "source_url": null, "captured_at": nul